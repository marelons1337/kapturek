<p id="notice"><%= notice %></p>

<h1>Buildings</h1>

<!-- Card group -->
 <div class="card-group">
  <% @buildings.each do |building| %>
    <div class="card">
      <div class="card-body">
        <h5 class="card-title"><%= building.name %></h5>
        <p class="card-text"><%= building.address %></p>
        <p class="card-text">
        <%= "#{I18n.t('buildings.flats_taken')}: #{building.flats_taken_display}" %>
        <%= "#{I18n.t('buildings.total_due')}: #{building.total_due} / #{building.total_revenue}"%>
        </p>
        <p class="card-text"><small class="text-muted"></small></p>
      </div>
    </div>
  <% end %>
</div>


<table class="table table-striped">
  <thead>
    <tr>
      <th scope="col">Name</th>
      <th scope="col">Address</th>
      <th scope="col">Flats amount</th>
      <th scope="col">Floors</th>
      <th scope="col">Tenants Count</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @buildings.each do |building| %>
      <tr>
        <td><%= building.name %></td>
        <td><%= building.address %></td>
        <td><%= building.flats_amount %></td>
        <td><%= building.floors %></td>
        <td><%= building.tenants_count %></td>
        <td><%= link_to 'Show', building %></td>
        <td><%= link_to 'Edit', edit_building_path(building) %></td>
        <td><%= link_to 'Destroy', building, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>


<%= link_to 'New Building', new_building_path %>
